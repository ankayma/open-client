{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ankayma",
  "version": "0.1.0",
  "identifier": "com.ankayma.app",
  "build": {
    "frontendDist": "../../frontend/app-gui/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../frontend/app-gui && npm run dev",
    "beforeBuildCommand": "cd ../frontend/app-gui && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Ankayma",
        "width": 920,
        "height": 760,
        "minWidth": 760,
        "minHeight": 680,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["ankayma"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 24,
      "debugApplicationIdSuffix": ".debug"
    },
    "iOS": {
      "minimumSystemVersion": "16.0"
    }
  }
}
