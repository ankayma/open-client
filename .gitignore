# Tauri mobile scaffolding — gen/android and gen/apple are checked in because
# they contain hand-written files (AndroidManifest.xml, AnkaymaVpnService.kt,
# MainActivity.kt, iOS entitlements, Xcode project). Inner .gitignore files
# inside gen/ exclude build artifacts, jniLibs, local.properties, etc.
# Only schemas (100% auto-generated on every build) are excluded here.
/gui/src-tauri/gen/schemas/
# CocoaPods install output — machine-local
/gui/src-tauri/gen/apple/Pods/
/gui/src-tauri/gen/apple/*.xcworkspace/

